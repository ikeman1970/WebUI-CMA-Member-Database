# Copy this file to .env and set your database connection.
# For local development you can use SQLite or a Supabase Postgres URL.

# SQLite example:
# DATABASE_URL="file:./dev.db"

# Supabase/Postgres example:
# DATABASE_URL="postgresql://postgres:<password>@db.cldgzfqoldsdpgcugbcj.supabase.co:5432/postgres"

DATABASE_URL="postgresql://postgres:<password>@db.cldgzfqoldsdpgcugbcj.supabase.co:5432/postgres"
NEXT_PUBLIC_APP_NAME="CMADirectoryApp"
NEXT_PUBLIC_SUPABASE_URL="https://cldgzfqoldsdpgcugbcj.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_I09sSrukgxutLf8RMIUEEA_VC2PdkPq"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"

# Optional one-time bootstrap root login.
# This only works when there are no existing root/superuser/admin accounts,
# and automatically stops working after the first admin is created.
BOOTSTRAP_ROOT_EMAIL="root@example.com"
BOOTSTRAP_ROOT_USERNAME="root"
BOOTSTRAP_ROOT_PASSWORD="change-me-now"

# Account invite onboarding defaults (safe-by-default for dev/test)
# Invite links are generated but email dispatch stays off unless explicitly enabled.
APP_BASE_URL="http://localhost:3000"
INVITE_TOKEN_EXPIRY_HOURS="72"
ENABLE_INVITE_EMAIL_SEND="false"
# Comma-separated emails allowed for real sends in non-production when ENABLE_INVITE_EMAIL_SEND=true
NON_PROD_EMAIL_ALLOWLIST=""
